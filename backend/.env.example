# Copy to .env and fill values.

# Database (create DB first: `createdb sbh` when using local Postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sbh

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
ENV=dev

# Capacity / booking (optional overrides)
# DEFAULT_BUCKET_MAX_CAPACITY=10
# DUPLICATE_BOOKING_WINDOW_HOURS=24
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

