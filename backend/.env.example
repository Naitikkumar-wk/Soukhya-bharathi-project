# Copy to .env and fill values.

# Database (create DB first: `createdb sbh` when using local Postgres)
DATABASE_URL=postgresql+psycopg://postgres:your-password@localhost:5432/sbh

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App
ENV=dev

# Capacity / booking (optional overrides)
# DEFAULT_BUCKET_MAX_CAPACITY=3
# DUPLICATE_BOOKING_WINDOW_HOURS=24
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# Email confirmation (mail-only)
# EMAIL_PROVIDER=stub
# EMAIL_TEMPLATE_ID=booking_confirmed_email
# EMAIL_FROM=noreply@soukhyabharathi.in
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-user
# SMTP_PASSWORD=your-password
# SMTP_USE_TLS=true
# SMTP_TIMEOUT_SECONDS=15

# Captcha (Cloudflare Turnstile)
# CAPTCHA_ENABLED=false
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key
# TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

